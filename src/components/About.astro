---
import { siteConfig } from "../config";
---

<section id="about" class="p-6 sm:p-10 md:p-14 lg:p-20">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12 items-start">
      <div class="lg:col-span-4">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl xl:text-5xl font-bold text-gray-900"
        >
          À propos de moi 
        </h2>
        <div
          class="w-[48px] h-[3px] mt-2 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        >
        </div>
      </div>

      <div class="lg:col-span-8 space-y-6">
        <p class="text-sm sm:text-base md:text-lg leading-relaxed text-gray-600">
          {siteConfig.aboutMe}
        </p>

        <div class="pt-2">
          <div class="flex flex-wrap gap-2">
            {
              siteConfig.skills.map((skill) => (
                <span class="px-2.5 sm:px-3 py-1 sm:py-1.5 bg-gray-100 text-gray-700 rounded-full text-xs sm:text-sm font-medium hover:bg-gray-200 transition-colors duration-200">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
